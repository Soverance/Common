  },
  "license": "MIT",
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.183.0",
    "@react-three/fiber": "^9.0.0"
  },
  "peerDependenciesMeta": {
    "three": { "optional": true },
    "@react-three/fiber": { "optional": true }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.183.0",
    "@react-three/fiber": "^9.5.0",
    "three": "^0.183.0",
    "typescript": "~5.8.0"
  }
