{
  "name": "@soverance/web",
  "version": "1.1.0",
  "description": "Shared React/TypeScript components and theming for Soverance applications",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
